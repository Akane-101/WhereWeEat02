  m_Script: {fileID: 11500000, guid: 141e0ca2e6faae549b749b2c7997d735, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  nextSceneName: Scene2
  openingDialogue:
    lines:
    - speaker: Country Moiuse
      content: What a nice day.
    - speaker: Country Moiuse
      content: 'Go find something to eat. '
  openingDelay: 3
  pickupDialogues:
  - lines:
    - speaker: 
      content: '*food / dry crumbs '
  - lines:
    - speaker: 
      content: '*food / fruit core '
    - speaker: Country Moiuse
      content: "It\u2019s a trace of human activity. "
  - lines:
    - speaker: 
      content: '*food / grain of wheat '
    - speaker: Country Moiuse
      content: 'Things often fall down here. '
  finalDialogue:
    lines:
    - speaker: ???
      content: (rustling noises)
    - speaker: Country Moiuse
      content: "Oh. It\u2019s my cousin. "
    - speaker: City Moiuse
      content: "Cousin, long time no see. You\u2019re still living in a place like
        this and eating this kind of food, huh? "
    - speaker: Country Moiuse
      content: "What\u2019s wrong with this place? "
    - speaker: City Moiuse
      content: "Come with me. Once you see where I live, you\u2019ll understand.
        The food there must be even better than you imagine. "
  finalDelay: 5
  targetCount: 3
